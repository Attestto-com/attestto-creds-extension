  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Attestto-com/attestto-creds-extension"
  },
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt --browser firefox",
    "build": "wxt build",
    "build:firefox": "wxt build --browser firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip --browser firefox",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "type-check": "vue-tsc --noEmit",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "@sd-jwt/decode": "^0.19.0",
    "@sd-jwt/present": "^0.19.0",
    "@sd-jwt/types": "^0.19.0",
    "@solana/web3.js": "^1.95.0",
    "axios": "^1.13.2",
    "jose": "^6.1.3",
    "pinia": "^3.0.4",
    "vue": "^3.5.24",
    "vue-i18n": "^11.2.8",
    "vue-router": "^4.6.4",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@heroicons/vue": "^2.2.0",
    "@tailwindcss/vite": "^4.1.18",
    "@tsconfig/node20": "^20.1.9",
    "@types/chrome": "^0.0.287",
    "@types/node": "^24.10.1",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vitest/coverage-v8": "^4.0.18",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.1",
    "@wxt-dev/module-vue": "^1.0.0",
    "happy-dom": "^20.3.4",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.9.3",
    "vite": "^7.2.4",
    "vitest": "^4.0.18",
    "vue-tsc": "^3.1.4",
    "wxt": "^0.20.0"
  }
